#!/usr/bin/env bash
# Regenerate packaging/.SRCINFO whenever packaging/PKGBUILD is staged.
#
# Without this, the in-repo .SRCINFO drifts from the in-repo PKGBUILD
# every time someone bumps pkgver / pkgrel / deps and forgets to run
# `makepkg --printsrcinfo` by hand. The AUR clone has its own .SRCINFO
# (regenerated at release time), so the drift only shows up here.
#
# Enable this hook with:
#     git config core.hooksPath .githooks
#
# Notes:
# - Reads the *staged* PKGBUILD content (`git show :packaging/PKGBUILD`)
#   so the regenerated .SRCINFO matches exactly what's about to be
#   committed, regardless of any unstaged tweaks in the working tree.
# - Silently skips when `makepkg` isn't on PATH (e.g. running this hook
#   on a non-Arch CI worker). The pre-commit then becomes a no-op
#   instead of a hard failure.
# - Re-stages the regenerated .SRCINFO so the developer doesn't need
#   to remember to `git add` it.

set -euo pipefail

if ! git diff --cached --name-only | grep -qE '^packaging/PKGBUILD$'; then
    exit 0
fi

if ! command -v makepkg >/dev/null 2>&1; then
    echo "pre-commit: makepkg not on PATH; skipping packaging/.SRCINFO regen" >&2
    exit 0
fi

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

git show :packaging/PKGBUILD > "$tmp/PKGBUILD"

# makepkg refuses to run as root; the user shouldn't be committing as
# root anyway, but keep the failure mode obvious.
if [ "$(id -u)" -eq 0 ]; then
    echo "pre-commit: refusing to run makepkg as root; skipping .SRCINFO regen" >&2
    exit 0
fi

(cd "$tmp" && makepkg --printsrcinfo) > packaging/.SRCINFO
git add packaging/.SRCINFO

echo "pre-commit: regenerated packaging/.SRCINFO from staged PKGBUILD"
